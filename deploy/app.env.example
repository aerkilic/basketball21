APP_IMAGE_NAME=basketball21-app
APP_IMAGE_TAG=latest
APP_CONTAINER_NAME=basketball21-app
APP_HOST_PORT=8000

APP_VERSION=v1.0.0
BUILD_TIME_BERLIN=auto

DEBUG=False
SECRET_KEY=change-me-in-production

DB_NAME=basketball21_db
DB_USER=basketball21_user
DB_PASSWORD=change-me
DB_HOST=host.docker.internal
DB_PORT=5432

# Run initial seed/schedule import at container startup.
# Set to true only for first boot or explicit reseed.
RUN_SEED_ON_START=false
