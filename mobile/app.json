{
  "expo": {
    "name": "basketball21",
    "slug": "basketball21",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f2f6fc"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.example.basketball21"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.example.basketball21"
    },
    "web": {
      "bundler": "metro"
    }
  }
}
